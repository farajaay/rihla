generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deviceType      String?  @map("device_type") @db.VarChar(50)
  browserLanguage String?  @map("browser_language") @db.VarChar(10)
  timezone        String?  @db.VarChar(50)
  referralSource  String?  @map("referral_source")
  consentGiven    Boolean  @default(false) @map("consent_given")
  ipHash          String?  @map("ip_hash") @db.VarChar(64)

  // Advertising attribution — populated from URL params on session creation
  idfaRaw     String?  @map("idfa_raw") @db.VarChar(64)    // iOS IDFA (raw — used for ad platform matching)
  gaidRaw     String?  @map("gaid_raw") @db.VarChar(64)    // Android GAID/AAID
  fbclid      String?  @map("fbclid") @db.VarChar(250)     // Facebook Click ID
  gclid       String?  @map("gclid") @db.VarChar(250)      // Google Click ID
  ttclid      String?  @map("ttclid") @db.VarChar(250)     // TikTok Click ID
  snapclid    String?  @map("snapclid") @db.VarChar(250)   // Snapchat Click ID
  utmSource   String?  @map("utm_source") @db.VarChar(100)
  utmMedium   String?  @map("utm_medium") @db.VarChar(100)
  utmCampaign String?  @map("utm_campaign") @db.VarChar(200)
  utmContent  String?  @map("utm_content") @db.VarChar(200)
  utmTerm     String?  @map("utm_term") @db.VarChar(200)

  profile             TravelerProfile?
  personalityProfile  PersonalityProfile?
  conversations       Conversation[]
  itineraries         Itinerary[]

  @@map("sessions")
}

model TravelerProfile {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId           String   @unique @map("session_id") @db.Uuid
  travelArchetype     String?  @map("travel_archetype") @db.VarChar(50)
  decisionDriver      String?  @map("decision_driver") @db.VarChar(50)
  groupType           String?  @map("group_type") @db.VarChar(20)
  groupSize           Int?     @map("group_size")
  isDecisionMaker     Boolean? @map("is_decision_maker")
  budgetTier          String?  @map("budget_tier") @db.VarChar(20)
  budgetCeilingSar    Int?     @map("budget_ceiling_sar")
  comfortThreshold    String?  @map("comfort_threshold") @db.VarChar(20)
  riskAppetite        String?  @map("risk_appetite") @db.VarChar(10)
  spontaneityScore    Float?   @map("spontaneity_score")
  valueDefinition     String?  @map("value_definition")
  destinationsMentioned String[] @map("destinations_mentioned")
  activitiesPreferred String[] @map("activities_preferred")
  accommodationPref   String?  @map("accommodation_pref") @db.VarChar(30)
  foodRestrictions    String[] @map("food_restrictions")
  adSegments          String[] @map("ad_segments")
  emotionalMarkers    String[] @map("emotional_markers")
  dateSignals         String[] @map("date_signals")
  engagementScore     Float    @default(0) @map("engagement_score")
  decisionReadiness   String?  @map("decision_readiness") @db.VarChar(20)
  profileCompleteness Float    @default(0) @map("profile_completeness")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itineraries Itinerary[]

  @@map("traveler_profiles")
}

model Conversation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  role           String   @db.VarChar(10)
  content        String
  profileSignals Json?    @map("profile_signals")
  tokenCount     Int?     @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("conversations")
}

model Itinerary {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String   @map("session_id") @db.Uuid
  profileId         String?  @map("profile_id") @db.Uuid
  parentId          String?  @map("parent_id") @db.Uuid
  revision          Int      @default(1)
  refinementRequest String?  @map("refinement_request")
  title             String?
  destination       String?
  durationDays      Int?     @map("duration_days")
  budgetTier        String?  @map("budget_tier") @db.VarChar(20)
  totalSarEstimate  Int?     @map("total_sar_estimate")
  itineraryJson     Json?    @map("itinerary_json")
  pdfUrl            String?  @map("pdf_url")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  session  Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  profile  TravelerProfile? @relation(fields: [profileId], references: [id])
  parent   Itinerary?       @relation("ItineraryRevisions", fields: [parentId], references: [id], onDelete: SetNull)
  children Itinerary[]      @relation("ItineraryRevisions")

  @@index([sessionId, createdAt])
  @@map("itineraries")
}

model PersonalityProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String   @unique @map("session_id") @db.Uuid

  // 5-dimension scores (0–100)
  noveltyDrive      Float    @default(50) @map("novelty_drive")
  socialDrive       Float    @default(50) @map("social_drive")
  statusDrive       Float    @default(50) @map("status_drive")
  planningStyle     Float    @default(50) @map("planning_style")
  sensoryMode       Float    @default(50) @map("sensory_mode")

  // Derived category labels
  noveltyCategory   String   @default("balanced") @map("novelty_category") @db.VarChar(30)
  socialCategory    String   @default("balanced") @map("social_category") @db.VarChar(30)
  statusCategory    String   @default("balanced") @map("status_category") @db.VarChar(30)
  planningCategory  String   @default("balanced") @map("planning_category") @db.VarChar(30)
  sensoryCategory   String   @default("balanced") @map("sensory_category") @db.VarChar(30)

  // Urge prediction
  nextUrge          String?  @map("next_urge") @db.VarChar(50)
  urgeConfidence    Float    @default(0) @map("urge_confidence")
  predictedTriggers String[] @map("predicted_triggers")

  // Decision stage
  decisionStage     String   @default("dreaming") @map("decision_stage") @db.VarChar(20)

  // Meta
  lastAssessedAt    DateTime @default(now()) @map("last_assessed_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("personality_profiles")
}

model AdSegmentsExport {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  segments   String[]
  budgetTier String?  @map("budget_tier") @db.VarChar(20)
  destinations String[]
  createdAt  DateTime @default(now()) @map("created_at") @db.Date

  @@map("ad_segments_export")
}
