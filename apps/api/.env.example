# Database
DATABASE_URL="postgresql://rihla:rihla_dev_pw@localhost:5432/rihla_db"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# Redis (Upstash for prod, local for dev)
REDIS_URL="redis://localhost:6379"

# App
PORT=3000
NODE_ENV=development
JWT_SECRET="change-me-to-a-random-256-bit-secret"
JWT_REFRESH_SECRET="change-me-to-a-different-random-secret"

# CORS
FRONTEND_URL="http://localhost:5173"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Admin
ADMIN_TOKEN=""

# Analytics (PostHog) — optional; events are no-op without these
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# Error reporting (Sentry) — optional
SENTRY_DSN=""

# Cloudflare R2 (for PDF storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="rihla-itineraries"
R2_PUBLIC_URL=""
